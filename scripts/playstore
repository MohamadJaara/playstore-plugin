#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CLI_ENTRY="${PLUGIN_ROOT}/cli/dist/index.js"

if [[ ! -f "${CLI_ENTRY}" ]]; then
  echo "playstore CLI has not been built yet. Run: npm --prefix \"${PLUGIN_ROOT}/cli\" run build" >&2
  exit 1
fi

exec node "${CLI_ENTRY}" "$@"
